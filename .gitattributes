# Normalize line endings to LF for all text files
* text=auto eol=lf

# Source code
*.astro text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.jsonc text eol=lf
*.css text eol=lf
*.md text eol=lf
*.mdx text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.html text eol=lf
*.svg text eol=lf
*.xml text eol=lf

# Config files
.gitattributes text eol=lf
.gitignore text eol=lf
.prettierrc text eol=lf
.prettierignore text eol=lf
.editorconfig text eol=lf
LICENSE text eol=lf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
*.mp4 binary
*.mov binary
*.mp3 binary
*.wav binary
*.pdf binary
