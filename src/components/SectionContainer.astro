---
interface Props {
  id?: string
  class?: string
}

const { class: className = "", id } = Astro.props
---

<section
  id={id ?? undefined}
  data-section={id ?? undefined}
  class={`section ${className} scroll-m-20 w-full mx-auto container lg:max-w-4xl md:max-w-2xl`.trim()}
>
  <slot />
</section>
