---
interface Props {
  beforeTitle?: string
  beforeItems: string[]
  afterTitle?: string
  afterItems: string[]
  context?: string
}

const {
  beforeTitle = "Before",
  beforeItems,
  afterTitle = "After",
  afterItems,
  context,
} = Astro.props
---

<div class="not-prose my-10">
  {context && (
    <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">
      {context}
    </p>
  )}

  <div class="grid grid-cols-1 md:grid-cols-[1fr_auto_1fr] gap-4 items-start">
    <!-- Before -->
    <div class="rounded-xl border border-red-200 dark:border-red-900/40 bg-red-50/60 dark:bg-red-950/20 p-5">
      <h3 class="flex items-center gap-2 text-sm font-semibold text-red-700 dark:text-red-400 mb-3">
        <span class="flex items-center justify-center w-5 h-5 rounded-full bg-red-100 dark:bg-red-900/40 text-xs">
          ✕
        </span>
        {beforeTitle}
      </h3>
      <ul class="space-y-2">
        {beforeItems.map((item) => (
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="mt-0.5 shrink-0 w-1 h-1 rounded-full bg-red-400"></span>
            {item}
          </li>
        ))}
      </ul>
    </div>

    <!-- Arrow -->
    <div class="flex md:flex-col items-center justify-center py-2 md:py-0">
      <span class="text-2xl text-yellow-500 dark:text-yellow-400 md:rotate-0 rotate-90">
        →
      </span>
    </div>

    <!-- After -->
    <div class="rounded-xl border border-green-200 dark:border-green-900/40 bg-green-50/60 dark:bg-green-950/20 p-5">
      <h3 class="flex items-center gap-2 text-sm font-semibold text-green-700 dark:text-green-400 mb-3">
        <span class="flex items-center justify-center w-5 h-5 rounded-full bg-green-100 dark:bg-green-900/40 text-xs">
          ✓
        </span>
        {afterTitle}
      </h3>
      <ul class="space-y-2">
        {afterItems.map((item) => (
          <li class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-300">
            <span class="mt-0.5 shrink-0 w-1 h-1 rounded-full bg-green-400"></span>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </div>
</div>
