---
interface Props {
  title?: string
  beforeLabel?: string
  beforeCode: string
  afterLabel?: string
  afterCode: string
  context?: string
}

const {
  title,
  beforeLabel = "Before",
  beforeCode,
  afterLabel = "After",
  afterCode,
  context,
} = Astro.props
---

<div class="not-prose my-10">
  {title && (
    <h3 class="text-lg font-semibold text-gray-800 dark:text-white mb-3">
      {title}
    </h3>
  )}
  {context && (
    <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">
      {context}
    </p>
  )}

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <!-- Before -->
    <div class="rounded-xl overflow-hidden border border-red-200 dark:border-red-900/40">
      <div class="flex items-center justify-between px-4 py-2 bg-red-50 dark:bg-red-950/30 border-b border-red-200 dark:border-red-900/40">
        <span class="text-xs font-semibold text-red-700 dark:text-red-400 uppercase tracking-wide">
          {beforeLabel}
        </span>
        <span class="text-[10px] text-red-400 font-mono">OLD</span>
      </div>
      <pre class="p-4 text-sm font-mono leading-relaxed text-gray-700 dark:text-gray-300 bg-red-50/30 dark:bg-red-950/10 whitespace-pre overflow-x-auto m-0"><code>{beforeCode}</code></pre>
    </div>

    <!-- After -->
    <div class="rounded-xl overflow-hidden border border-green-200 dark:border-green-900/40">
      <div class="flex items-center justify-between px-4 py-2 bg-green-50 dark:bg-green-950/30 border-b border-green-200 dark:border-green-900/40">
        <span class="text-xs font-semibold text-green-700 dark:text-green-400 uppercase tracking-wide">
          {afterLabel}
        </span>
        <span class="text-[10px] text-green-400 font-mono">NEW</span>
      </div>
      <pre class="p-4 text-sm font-mono leading-relaxed text-gray-700 dark:text-gray-300 bg-green-50/30 dark:bg-green-950/10 whitespace-pre overflow-x-auto m-0"><code>{afterCode}</code></pre>
    </div>
  </div>
</div>
