---
import ThemeToggle from "./ThemeToggle.astro"
import { NAV_ITEMS } from "@/data/navigation"

const navItems = NAV_ITEMS
---

<header
  class="fixed top-0 z-10 flex items-center justify-center w-full mx-auto mt-4"
>
  <nav
    class="header-nav flex gap-x-1 px-4 py-1.5 text-sm font-medium rounded-full text-gray-700 dark:text-white justify-center items-center"
  >
    {
      navItems.map((link) => (
        <a
          class="nav-link relative text-xs sm:text-sm block px-1.5 sm:px-3 py-2 sm:py-1.5 rounded-full transition-colors duration-200 hover:text-yellow-500 dark:hover:text-yellow-400"
          aria-label={link.label}
          href={link.url}
        >
          {link.title}
        </a>
      ))
    }
    <div class="ml-2 pl-2 border-l border-gray-300/30 dark:border-white/10">
      <ThemeToggle />
    </div>
  </nav>
</header>

<script>
  document.addEventListener("astro:page-load", () => {
    const previousController = (window as any).__headerNavController as
      AbortController | undefined
    previousController?.abort()

    const controller = new AbortController()
    ;(window as any).__headerNavController = controller

    const navItems = Array.from(
      document.querySelectorAll<HTMLAnchorElement>("header nav a[aria-label]"),
    )
    const navLabels = new Set(navItems.map((item) => item.ariaLabel))
    const sections = Array.from(
      document.querySelectorAll<HTMLElement>("section[id]"),
    ).filter((section) => navLabels.has(section.id))

    const activeClasses = [
      "text-yellow-500",
      "dark:text-yellow-400",
      "bg-yellow-400/10",
    ]
    const inactiveClasses = ["text-gray-700", "dark:text-white"]

    const setActiveNavItem = (sectionId: string): void => {
      navItems.forEach((item) => {
        const isActive = item.ariaLabel === sectionId

        item.classList.toggle(activeClasses[0], isActive)
        item.classList.toggle(activeClasses[1], isActive)
        item.classList.toggle(activeClasses[2], isActive)
        item.classList.toggle(inactiveClasses[0], !isActive)
        item.classList.toggle(inactiveClasses[1], !isActive)
      })
    }

    const getActiveSectionId = (): string | undefined => {
      const isNearPageBottom =
        window.innerHeight + window.scrollY >= document.body.scrollHeight - 4

      if (isNearPageBottom) {
        return sections.at(-1)?.id
      }

      const marker = Math.min(window.innerHeight * 0.35, 260)
      let activeSectionId = sections[0]?.id

      for (const section of sections) {
        const rect = section.getBoundingClientRect()

        if (rect.top <= marker) {
          activeSectionId = section.id
        }

        if (rect.top <= marker && rect.bottom > marker) {
          return section.id
        }
      }

      return activeSectionId
    }

    let rafId = 0
    const updateActiveNavItem = (): void => {
      cancelAnimationFrame(rafId)
      rafId = requestAnimationFrame(() => {
        const activeSectionId = getActiveSectionId()

        if (activeSectionId) {
          setActiveNavItem(activeSectionId)
        }
      })
    }

    navItems.forEach((item) => {
      item.addEventListener(
        "click",
        () => {
          const href = item.getAttribute("href")
          const hash = href?.startsWith("/#") ? href.slice(2) : undefined

          if (hash && navLabels.has(hash)) {
            setActiveNavItem(hash)
          }
        },
        { signal: controller.signal },
      )
    })

    updateActiveNavItem()
    window.addEventListener("scroll", updateActiveNavItem, {
      passive: true,
      signal: controller.signal,
    })
    window.addEventListener("resize", updateActiveNavItem, {
      signal: controller.signal,
    })
    window.addEventListener("hashchange", updateActiveNavItem, {
      signal: controller.signal,
    })
  })
</script>

<style>
  .header-nav {
    animation: nav-appear 1s linear both;
    animation-timeline: scroll();
    animation-range: 0 100px;

    --nav-bg: rgba(255, 255, 255, 0.82);
    --nav-border: rgba(17, 24, 39, 0.12);
    --nav-shadow:
      0 10px 28px -18px rgba(17, 24, 39, 0.45),
      0 1px 0 rgba(255, 255, 255, 0.8) inset;

    background-color: var(--nav-bg);
    border: 1px solid var(--nav-border);
    box-shadow: var(--nav-shadow);
    backdrop-filter: blur(14px);
  }

  :global(.dark) .header-nav {
    --nav-bg: rgba(3, 7, 18, 0.86);
    --nav-border: rgba(255, 255, 255, 0.16);
    --nav-shadow:
      0 14px 34px -18px rgba(0, 0, 0, 0.9),
      0 0 0 1px rgba(255, 255, 255, 0.04) inset;
  }

  .nav-link.text-yellow-500 {
    @apply font-semibold;
  }

  @keyframes nav-appear {
    0% {
      background-color: var(--nav-bg);
      border-color: var(--nav-border);
      box-shadow: var(--nav-shadow);
      backdrop-filter: blur(10px);
    }
    to {
      background-color: var(--nav-bg);
      box-shadow: var(--nav-shadow);
      backdrop-filter: blur(12px);
      border-color: var(--nav-border);
    }
  }
</style>
