---
import ThemeToggle from "./ThemeToggle.astro"
import { NAV_ITEMS } from "@/data/navigation"

const navItems = NAV_ITEMS
---

<header
  class="fixed top-0 z-10 flex items-center justify-center w-full mx-auto mt-4"
>
  <nav
    class="header-nav flex gap-x-1 px-4 py-1.5 text-sm font-medium rounded-full text-gray-700 dark:text-white justify-center items-center"
  >
    {
      navItems.map((link) => (
        <a
          class="nav-link relative text-xs sm:text-sm block px-1.5 sm:px-3 py-2 sm:py-1.5 rounded-full transition-colors duration-200 hover:text-yellow-500 dark:hover:text-yellow-400"
          aria-label={link.label}
          href={link.url}
        >
          {link.title}
        </a>
      ))
    }
    <div class="ml-2 pl-2 border-l border-gray-300/30 dark:border-white/10">
      <ThemeToggle />
    </div>
  </nav>
</header>

<script>
  document.addEventListener("astro:page-load", () => {
    const sections = document.querySelectorAll("section")
    const navItems = document.querySelectorAll("header nav a")

    const callback = (entries: any[]) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          navItems.forEach((item) => {
            if (item.getAttribute("aria-label") == entry.target.id) {
              item.classList.add(
                "text-yellow-500",
                "dark:text-yellow-400",
                "bg-yellow-400/10",
              )
              item.classList.remove("text-gray-700", "dark:text-white")
            } else {
              item.classList.remove(
                "text-yellow-500",
                "dark:text-yellow-400",
                "bg-yellow-400/10",
              )
              item.classList.add("text-gray-700", "dark:text-white")
            }
          })
        }
      })
    }

    const observer = new IntersectionObserver(callback, {
      root: null,
      rootMargin: "0px",
      threshold: 0.3,
    })

    sections.forEach((section) => {
      observer.observe(section)
    })

    document.onvisibilitychange = () => {
      if (document.visibilityState === "hidden") {
        observer.disconnect()
      } else {
        sections.forEach((section) => {
          observer.observe(section)
        })
      }
    }
  })
</script>

<style>
  .header-nav {
    animation: nav-appear 1s linear both;
    animation-timeline: scroll();
    animation-range: 0 100px;

    --nav-bg: rgba(255, 255, 255, 0.82);
    --nav-border: rgba(17, 24, 39, 0.12);
    --nav-shadow:
      0 10px 28px -18px rgba(17, 24, 39, 0.45),
      0 1px 0 rgba(255, 255, 255, 0.8) inset;

    background-color: var(--nav-bg);
    border: 1px solid var(--nav-border);
    box-shadow: var(--nav-shadow);
    backdrop-filter: blur(14px);
  }

  :global(.dark) .header-nav {
    --nav-bg: rgba(3, 7, 18, 0.86);
    --nav-border: rgba(255, 255, 255, 0.16);
    --nav-shadow:
      0 14px 34px -18px rgba(0, 0, 0, 0.9),
      0 0 0 1px rgba(255, 255, 255, 0.04) inset;
  }

  .nav-link.text-yellow-500 {
    @apply font-semibold;
  }

  @keyframes nav-appear {
    0% {
      background-color: var(--nav-bg);
      border-color: var(--nav-border);
      box-shadow: var(--nav-shadow);
      backdrop-filter: blur(10px);
    }
    to {
      background-color: var(--nav-bg);
      box-shadow: var(--nav-shadow);
      backdrop-filter: blur(12px);
      border-color: var(--nav-border);
    }
  }
</style>
