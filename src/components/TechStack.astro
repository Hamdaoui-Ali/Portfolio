---
import { TECHNOLOGIES } from "@/data/technologies"

const STACK_GROUPS = [
  {
    title: "Backend",
    keys: ["JAVA", "SPRING_BOOT", "NET", "FASTAPI", "DJANGO", "FLASK"],
  },
  {
    title: "Frontend",
    keys: ["ANGULAR", "REACT", "ASTRO", "TAILWIND", "TYPESCRIPT", "BOOTSTRAP"],
  },
  {
    title: "Data & BI",
    keys: [
      "SQL_SERVER",
      "SSIS",
      "SSAS",
      "POWER_BI",
      "MYSQL",
      "POSTGRESQL",
      "SQLITE",
      "MONGODB",
    ],
  },
  {
    title: "Automation & Testing",
    keys: ["SELENIUM", "PYTEST", "JUNIT", "POSTMAN", "PYTHON"],
  },
  {
    title: "DevOps & Cloud",
    keys: ["DOCKER", "KUBERNETES", "AZURE", "AWS", "GITHUB_ACTIONS", "VERCEL"],
  },
  {
    title: "AI & Modernization",
    keys: ["AZURE_OPENAI", "LLM_MIGRATION", "CODE_ANALYSIS"],
  },
]
---

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
  {
    STACK_GROUPS.map((group) => {
      const techs = group.keys.map((key) => TECHNOLOGIES[key]).filter(Boolean)

      return (
        <div class="rounded-xl border border-gray-200 dark:border-gray-800 p-5 bg-white/60 dark:bg-gray-900/60">
          <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-4">
            {group.title}
          </h3>
          <ul class="flex flex-row flex-wrap gap-2">
            {techs.map((tech) => (
              <li>
                <span
                  class={`flex items-center gap-x-1.5 rounded-full text-xs ${tech.class} py-1 px-2.5`}
                >
                  {tech.name}
                </span>
              </li>
            ))}
          </ul>
        </div>
      )
    })
  }
</div>
